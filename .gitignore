# pyenv
#   For a library or binary, you wish to ignore these files personally, then
#   add them to your global gitignore.
# .python-version

# pipenv
#   According to pypa/pipenv#1173, it is recommended not to include
#   Pipfile.lock in version control.
#   However, in case of collaboration, if you want to share the exact same environment
#   you should commit it.
# Pipfile.lock

# poetry
#   Similar to Pipenv, it is generally recommended to include poetry.lock in version control.
#   https://python-poetry.org/docs/basic-usage/#commit-your-poetrylock-file-to-version-control
# poetry.lock

# pdm
#   Similar to Pipenv, it is generally recommended to include pdm.lock in version control.
#   https://pdm.fming.dev/#commit-your-pdmlock-file-to-version-control
# pdm.lock

# PEP 582; used by e.g. github.com/frenzyryz/pipflow
__pypackages__/

# Celery stuff
celerybeat-schedule
celerybeat.pid

# SageMath parsed files
*.sage.py

